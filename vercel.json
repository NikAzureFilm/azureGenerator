{
  "rewrites": [
    {
      "source": "/cadam",
      "destination": "/cadam/index.html"
    },
    {
      "source": "/cadam/",
      "destination": "/cadam/index.html"
    },
    {
      "source": "/cadam/assets/:path*",
      "destination": "/cadam/assets/:path*"
    },
    {
      "source": "/cadam/:path*",
      "destination": "/cadam/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/cadam/",
      "permanent": false
    }
  ],
  "trailingSlash": false
}
